// ==========================================
// 💾 1. CAMADA DE PERSISTÊNCIA (STORAGE/CRUD)
// ==========================================
const STORAGE_KEY = '@zelabairro:ocorrencias';

const OcorrenciaStorage = {
  // CREATE
  async save(ocorrencia) {
    try {
      const atuais = await this.getAll();
      const novas = [...atuais, ocorrencia];
      await AsyncStorage.setItem(STORAGE_KEY, JSON.stringify(novas));
    } catch (error) {
      console.error("Erro ao salvar ocorrência:", error);
    }
  },

  // READ
  async getAll() {
    try {
      const dados = await AsyncStorage.getItem(STORAGE_KEY);
      return dados ? JSON.parse(dados) : [];
    } catch (error) {
      console.error("Erro ao buscar ocorrências:", error);
      return [];
    }
  },

  // UPDATE
  async update(ocorrenciaAtualizada) {
    try {
      const atuais = await this.getAll();
      const novas = atuais.map(item => 
        item.id === ocorrenciaAtualizada.id ? ocorrenciaAtualizada : item
      );
      await AsyncStorage.setItem(STORAGE_KEY, JSON.stringify(novas));
    } catch (error) {
      console.error("Erro ao atualizar ocorrência:", error);
    }
  },

  // DELETE
  async delete(id) {
    try {
      const atuais = await this.getAll();
      const filtradas = atuais.filter(item => item.id !== id);
      await AsyncStorage.setItem(STORAGE_KEY, JSON.stringify(filtradas));
    } catch (error) {
      console.error("Erro ao deletar ocorrência:", error);
    }
  }
};

