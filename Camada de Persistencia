function OcorrenciaCard({ item, onPress }) {
  const getStatusColor = (status) => {
    switch (status) {
      case 'Resolvido': return '#2e7d32';
      case 'Em Andamento': return '#f57c00';
      default: return '#d32f2f';
    }
  };

  return (
    <TouchableOpacity style={cardStyles.card} onPress={onPress}>
      <View style={cardStyles.header}>
        <Text style={cardStyles.title} numberOfLines={1}>{item.titulo}</Text>
        <View style={[cardStyles.badge, { backgroundColor: getStatusColor(item.status) }]}>
          <Text style={cardStyles.badgeText}>{item.status}</Text>
        </View>
      </View>
      <Text style={cardStyles.category}>📁 {item.categoria}</Text>
      <Text style={cardStyles.description} numberOfLines={2}>{item.descricao}</Text>
      <Text style={cardStyles.location}>📍 {item.localizacao}</Text>
    </TouchableOpacity>
  );
}

