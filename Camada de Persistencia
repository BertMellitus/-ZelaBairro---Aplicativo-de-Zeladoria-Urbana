          <Text style={homeStyles.emptyText}>Nenhuma ocorrência registrada. Seu bairro está limpo! 🎉</Text>
        }
        contentContainerStyle={homeStyles.list}
      />
      
      <TouchableOpacity 
        style={homeStyles.fab} 
        onPress={() => navigation.navigate('Formulário', { item: null })}
      >
        <Text style={homeStyles.fabText}>+</Text>
      </TouchableOpacity>
    </View>
  );
}

