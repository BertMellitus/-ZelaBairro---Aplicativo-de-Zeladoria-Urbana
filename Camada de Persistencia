// 📝 4. TELA: FORMULÁRIO (CRIAR / EDITAR)
// ==========================================
function FormScreen({ route, navigation }) {
  const editItem = route.params?.item;

  const [titulo, setTitulo] = useState(editItem ? editItem.titulo : '');
  const [categoria, setCategoria] = useState(editItem ? editItem.categoria : 'Iluminação');
  const [descricao, setDescricao] = useState(editItem ? editItem.descricao : '');
  const [localizacao, setLocalizacao] = useState(editItem ? editItem.localizacao : '');

  const categorias = ['Iluminação', 'Buraco na Via', 'Foco de Dengue', 'Lixo Acumulado', 'Outros'];

  const salvar = async () => {
    if (!titulo || !descricao || !localizacao) {
      Alert.alert('Atenção', 'Preencha todos os campos obrigatórios.');
      return;
    }

    const ocorrencia = {
      id: editItem ? editItem.id : Date.now().toString(),
      titulo,
      categoria,
      descricao,
      localizacao,
      status: editItem ? editItem.status : 'Pendente',
    };

    if (editItem) {
      await OcorrenciaStorage.update(ocorrencia);
    } else {
      await OcorrenciaStorage.save(ocorrencia);
    }

    navigation.navigate('Início');
  };

  return (
    <ScrollView style={formStyles.container}>
      <Text style={formStyles.label}>Título da Ocorrência *</Text>
      <TextInput style={formStyles.input} value={titulo} onChangeText={setTitulo} placeholder="Ex: Poste apagado há 3 dias" />

      <Text style={formStyles.label}>Categoria</Text>
      <View style={formStyles.categoryContainer}>
        {categorias.map((cat) => (
          <TouchableOpacity 
            key={cat} 
            style={[formStyles.categoryButton, categoria === cat && formStyles.categoryButtonActive]}
            onPress={() => setCategoria(cat)}
          >
            <Text style={[formStyles.categoryButtonText, categoria === cat && formStyles.categoryButtonTextActive]}>{cat}</Text>
          </TouchableOpacity>
        ))}
      </View>

      <Text style={formStyles.label}>Descrição Detalhada *</Text>
      <TextInput 
        style={[formStyles.input, formStyles.textArea]} 
        value={descricao} 
        onChangeText={setDescricao} 
        placeholder="Descreva o problema..." 
        multiline
        numberOfLines={4}
      />

      <Text style={formStyles.label}>Localização / Endereço *</Text>
      <TextInput style={formStyles.input} value={localizacao} onChangeText={setLocalizacao} placeholder="Ex: Rua das Flores, em frente ao nº 123" />

      <TouchableOpacity style={formStyles.saveButton} onPress={salvar}>
        <Text style={formStyles.saveButtonText}>{editItem ? 'Atualizar Registro' : 'Registrar Problema'}</Text>
      </TouchableOpacity>
    </ScrollView>
  );
}

